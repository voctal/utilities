{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "utilities",
    "version": "0.0.0",
    "private": true,
    "description": "Useful TypeScript utilities",
    "bugs": {
        "url": "https://github.com/voctal/utilities/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/voctal/utilities.git"
    },
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "lint": "turbo run lint",
        "fmt": "oxfmt && turbo run fmt",
        "test": "turbo run test",
        "docs": "turbo run docs"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "tsdown": "^0.21.4",
        "turbo": "^2.8.20",
        "typescript": "^5.9.3",
        "vitest": "^4.1.1"
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@10.33.0"
}
