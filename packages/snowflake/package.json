{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@voctal/snowflake",
    "version": "1.0.3",
    "description": "Snowflake utility package",
    "keywords": [
        "id",
        "snowflake",
        "typescript",
        "utility",
        "voctal"
    ],
    "homepage": "https://github.com/voctal/utilities/tree/main/packages/snowflake",
    "bugs": {
        "url": "https://github.com/voctal/utilities/issues"
    },
    "license": "MIT",
    "author": "voctal",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/voctal/utilities.git",
        "directory": "packages/snowflake"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.cts",
    "exports": {
        ".": {
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.js"
            },
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            }
        }
    },
    "scripts": {
        "build": "tsdown --config-loader unrun",
        "build:docs": "tsc -p tsconfig.docs.json",
        "lint": "tsc --noEmit && oxlint && oxfmt --check",
        "fmt": "oxfmt",
        "test": "vitest run",
        "docs": "npm run build:docs && api-extractor run --local"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.57.7",
        "tsdown": "^0.21.4",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=22"
    }
}
